# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Postgres (Supabase pooler). DATABASE_URL = transaction pooler (6543) for the
# serverless runtime; DIRECT_URL = session pooler (5432) for migrations/seed.
DATABASE_URL=
DIRECT_URL=

# --- LLM (pluggable). Active provider for the live demo = groq ---
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Coded + switchable alternates:
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-flash-latest
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- WhatsApp (pluggable). Active provider for the live demo = simulator ---
WHATSAPP_PROVIDER=simulator
SIM_SECRET=
# Cloud (Meta) provider, only needed when WHATSAPP_PROVIDER=cloud:
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# --- App ---
AI_DAILY_CAP=200
CRON_SECRET=
DEMO_ADMIN_EMAIL=admin@conversa.app
DEMO_AGENT_EMAIL=agent@conversa.app
DEMO_PASSWORD=demo1234
NEXT_PUBLIC_APP_URL=http://localhost:3000
